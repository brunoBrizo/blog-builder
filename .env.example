# -----------------------------------------------------------------------------
# Supabase (dev)
# -----------------------------------------------------------------------------
# Pooled connection (transaction pooler, port 6543) for runtime use (API, web).
# Use this for @blog-builder/db client at runtime.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres"

# Direct connection (port 5432) used by drizzle-kit for migrations/studio.
# Required because pooled connections don't support DDL transactions reliably.
DIRECT_DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"

# Supabase REST / Auth (backend + admin only).
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SECRET_KEY="sb_secret_xxx"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"

# -----------------------------------------------------------------------------
# API (apps/api) — mirrors apps/api/src/core/config/env.schema.ts
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Throttling (defaults; optional overrides)
# THROTTLE_PUBLIC_READ_LIMIT=120
# THROTTLE_PUBLIC_READ_TTL_MS=60000
# THROTTLE_PUBLIC_WRITE_LIMIT=30
# THROTTLE_PUBLIC_WRITE_TTL_MS=60000
# THROTTLE_ADMIN_LIMIT=60
# THROTTLE_ADMIN_TTL_MS=60000

# Integrations (required for boot)
PERPLEXITY_API_KEY="pplx-xxx"
RESEND_API_KEY="re_xxx"

# Shared secrets (generate strong random values)
CRON_SHARED_SECRET="dev-cron-secret"
REVALIDATE_SHARED_SECRET="dev-revalidate-secret"

# CORS: origin for apps/web (required in production)
CORS_ORIGIN_WEB="http://localhost:3000"

# Optional: restrict cron routes by IP (comma-separated CIDRs; empty = no restriction)
# CRON_IP_ALLOWLIST=""
# TRUST_PROXY=false

# Optional: Sentry
# SENTRY_DSN=""
# SENTRY_TRACES_SAMPLE_RATE=1

# Optional: build metadata (injected in CI)
# GIT_SHA=""
# RELEASE_TAG=""
# BUILT_AT=""

# Optional: integration tests / dev-only probes
# ENABLE_TEST_ENDPOINTS=true

# -----------------------------------------------------------------------------
# Web (apps/web)
# -----------------------------------------------------------------------------
# Public API base URL including /api prefix (browser + server)
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001/api"

# Server-only: same value as REVALIDATE_SHARED_SECRET on the API (for POST /api/revalidate)
# REVALIDATE_SHARED_SECRET="dev-revalidate-secret"
